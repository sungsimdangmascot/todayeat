<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
    PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
    
<mapper namespace="com.todayeat.mapper.MemberMapper">

	<!-- 회원 가입 -->
	<insert id="join" parameterType="com.todayeat.dto.MemberDTO">
		INSERT INTO MEMBER(MEMBER_LOGINID, MEMBER_PWD, MEMBER_NAME, 
			MEMBER_EMAIL) 
		VALUES(#{memberLoginId}, #{memberPwd}, #{memberName}, #{memberEmail})
	</insert>
	
	<!-- 아이디 중복 확인 -->
	<select id="findByLoginId" parameterType="String" resultType="com.todayeat.dto.MemberDTO">
		SELECT * FROM MEMBER WHERE MEMBER_LOGINID = #{memberLoginId}
	</select>
	
	<!-- 회원 1명의 정보 조회 -->
	<select id="findById" parameterType="int"
		resultType="com.todayeat.dto.MemberDTO">
		SELECT *
		FROM MEMBER
		WHERE MEMBER_ID = #{memberId}
	</select>
	
	<!-- 회원 이름만 수정 -->
	<update id="updateInfo" parameterType="com.todayeat.dto.MemberDTO">
		UPDATE MEMBER
			SET MEMBER_NAME = #{memberName}
		WHERE MEMBER_ID = #{memberId}
	</update>
	
	<!-- 비밀번호만  수정 -->
	<update id="updatePwd" parameterType="com.todayeat.dto.MemberDTO">
		UPDATE MEMBER
			SET MEMBER_PWD = #{memberPwd}
		WHERE MEMBER_ID = #{memberId}
	</update>
	
	<!-- 회원 탈퇴 신청 -->
	<update id="withdraw" parameterType="int">
		UPDATE MEMBER
			SET MEMBER_STATUS = 'WITHDRAW'
		WHERE MEMBER_ID = #{memberId}
	</update>
	
	<!-- 마이페이지 프로필 사진 수정 -->
	<update id="updateProfileImg" parameterType="com.todayeat.dto.MemberDTO">
		UPDATE MEMBER
			SET MEMBER_PROFILE_IMG = #{memberProfileImg}
		WHERE MEMBER_ID = #{memberId}
	</update>
	
	
	<!--
		소셜 타입 + 소셜 키로 연동된 회원 조회
		
		ex) socialType = "KAKAO", socialKey="12345"로 조회하면
		해당 카카오 계정으로 가입한 우리 DB 회원 정보가 반환됨
	-->
	<select id="findBySocial" resultType="com.todayeat.dto.MemberDTO">
		SELECT m.*
		FROM MEMBER m
			JOIN MEMBER_SOCIAL ms on m.MEMBER_ID = ms.MEMBER_ID
		WHERE ms.SOCIAL_TYPE = #{socialType}
			AND ms.SOCIAL_KEY = #{socialKey}
	</select>
	
	<!--
		MEMBER_SOCIAL 테이블에 소셜 연동 정보 INSERT
		카카오 첫 로그인 시 MEMBER 테이블에 회원을 만든 뒤
		MEMBER_SOCIAL에도 연동 정보를 저장
	-->
	<insert id="saveSocial" parameterType="com.todayeat.dto.MemberSocialDTO">
		INSERT INTO MEMBER_SOCIAL(MEMBER_ID, SOCIAL_TYPE, SOCIAL_KEY)
			VALUES(#{memberId}, #{socialType}, #{socialKey})
	</insert>
	
	<!-- 통계 : 정상 회원 수 -->
	<select id="countActiveMembers" resultType="int">
		SELECT COUNT(*)
		FROM MEMBER
		WHERE MEMBER_STATUS = 'ACTIVE'
	</select>
	
	<!-- 통계 : 탈퇴 신청 회원 수 -->
	<select id="countWithdrawMembers" resultType="int">
		SELECT COUNT(*)
		FROM MEMBER
		WHERE MEMBER_STATUS = 'WITHDRAW'	
	</select>
	
	<!--
		관리자 회원 목록 - 검색 + 페이징
	-->
	<select id="findMembersForAdmin" resultType="com.todayeat.dto.MemberDTO">
		SELECT *
		FROM MEMBER
		WHERE MEMBER_STATUS = 'ACTIVE'
		<if test="keyword != null and keyword != ''">
			AND (MEMBER_NAME LIKE CONCAT('%', #{keyword}, '%')
				OR MEMBER_EMAIL LIKE CONCAT('%', #{keyword}, '%'))
		</if>
		ORDER BY MEMBER_ID DESC
		LIMIT #{size} OFFSET #{offset}
	</select>
	
	<!-- 
		관리자 회원 목록 전체 건수 - 페이징 계산용
	 -->
	 <select id="countMembersForAdmin" resultType="int">
	 SELECT COUNT(*)
	 FROM MEMBER
	 WHERE MEMBER_STATUS = 'ACTIVE'
	<if test="keyword != null and keyword != ''">
		AND (MEMBER_NAME LIKE CONCAT('%', #{keyword}, '%')
		OR MEMBER_EMAIL LIKE CONCAT('%', #{keyword}, '%'))
	</if>
	</select>
	
	<!--
		연쇄 삭제용-이 회원의 소셜 로그인 연결 삭제
	-->
	<delete id="deleteSocialByMember" parameterType="int">
		DELETE FROM MEMBER_SOCIAL WHERE MEMBER_ID = #{memberId}
	</delete>
	
	<!-- 
		연쇄 삭제용-회원 삭제
	-->
	<delete id="deleteById" parameterType="int">
		DELETE FROM MEMBER WHERE MEMBER_ID = #{memberId}
	</delete>
	
	<!-- 탈퇴 신청 회원 목록 -->
	<select id="findWithdrawMembers" resultType="com.todayeat.dto.MemberDTO">
		SELECT *
		FROM MEMBER
		WHERE MEMBER_STATUS = 'WITHDRAW'
		ORDER BY MEMBER_ID DESC
	</select>
	
	
</mapper>








